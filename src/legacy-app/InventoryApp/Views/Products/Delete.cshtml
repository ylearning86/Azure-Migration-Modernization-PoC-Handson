@model InventoryApp.Models.Product

@{
    ViewBag.Title = "削除確認";
}

<h2>商品削除</h2>

<div class="card">
    <h3>以下の商品を削除しますか？</h3>

    <table>
        <tr><td><strong>ID</strong></td><td>@Model.Id</td></tr>
        <tr><td><strong>商品名</strong></td><td>@Model.Name</td></tr>
        <tr><td><strong>カテゴリ</strong></td><td>@Model.Category</td></tr>
        <tr><td><strong>単価</strong></td><td>@String.Format("¥{0:N0}", Model.Price)</td></tr>
        <tr><td><strong>在庫数</strong></td><td>@Model.Quantity</td></tr>
    </table>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()
        <br />
        <button type="submit" class="btn btn-danger">削除する</button>
        @Html.ActionLink("キャンセル", "Index", null, new { @class = "btn" })
    }
</div>
