{
    "servers": {
        "microsoft-learn": {
            "type": "http",
            "url": "https://learn.microsoft.com/api/mcp",
            "headers": {}
        },
        "azure": {
            "command": "npx",
            "args": ["-y", "@azure/mcp@latest", "server", "start"]
        },
        "playwright": {
            "command": "npx",
            "args": ["-y", "@playwright/mcp@latest", "--browser", "msedge"]
        }
    }
}
